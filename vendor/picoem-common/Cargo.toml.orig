[package]
name = "picoem-common"
version = "0.2.1"
edition.workspace = true
license.workspace = true
rust-version.workspace = true
description = "Shared primitives for the picoem RP2350/RP2040 emulator workspace: Memory, ClockTree, Pacer, PIO building blocks, threading helpers."
repository = "https://github.com/0x4D44/picoem"
homepage = "https://github.com/0x4D44/picoem"
documentation = "https://docs.rs/picoem-common"
readme = "README.md"
keywords = ["emulator", "rp2350", "rp2040", "embedded", "pico"]
categories = ["emulators", "embedded"]

[lints]
workspace = true

[features]
# Test-only hooks that expose otherwise-private PIO state (e.g. RX FIFO
# push) for cross-crate unit tests. NOT part of the production API —
# enabling this in a non-test build is a misconfiguration.
test-hooks = []

# PIO PSRAM-SPI pad-edge diagnostic counters
# (`pad_out_cs_falls`/`_rises`/`pad_out_sck_toggles`/
# `pad_out_mosi_writes_of_1`). Bumped from `PioBlock::step` per sysclk.
# Pure observation — no effect on emulation. Costs ~9% of `step_n`
# throughput on a 1-SM clkdiv=1 program (see
# `wrk_journals/2026.04.20 - JRN - PIO step_n Profiling.md`).
# Off by default; enable when running PicoGUS-style PSRAM-SPI diff
# work that needs the per-edge counters.
pio-pad-diag = []

[dependencies]
tracing = { workspace = true }

# Worker-thread affinity FFI for `threaded::worker::pin_to_host_core`
# (2026-04-30 Threaded Helpers Pull-Up HLD V1). Same per-OS deps already
# carried by both chip crates' Cargo.toml — Windows uses
# `SetThreadAffinityMask` from `winapi`; Linux uses
# `pthread_setaffinity_np` from `libc`.
[target.'cfg(all(target_arch = "x86_64", target_os = "windows"))'.dependencies]
winapi = { version = "0.3", features = ["processthreadsapi", "winbase"] }

[target.'cfg(all(target_arch = "x86_64", target_os = "linux"))'.dependencies]
libc = "0.2"
